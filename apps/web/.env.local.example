# Copy to .env.local

# Base URL where short links resolve (shown in UI)
# Local dev without Nginx:
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:3001
# Local dev with Nginx (docker compose up):
# NEXT_PUBLIC_SHORT_URL_BASE=http://localhost

# Internal API URL used by Next.js rewrites (server-side, not exposed to browser)
API_INTERNAL_URL=http://localhost:3001
